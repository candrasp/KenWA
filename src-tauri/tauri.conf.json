{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KenWa",
  "version": "1.0.0",
  "identifier": "com.kenwa.launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KenWa",
        "width": 500,
        "height": 400,
        "maxHeight": 600,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}