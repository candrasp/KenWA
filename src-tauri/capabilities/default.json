{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "KenWA default permissions — IPC + shell sidecar + OS info",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://wa.me/*" },
        { "url": "mailto:*" }
      ]
    },
    "os:default",
    "updater:default",
    "process:allow-restart"
  ]
}
